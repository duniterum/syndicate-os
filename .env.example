# The Syndicate OS — environment template (placeholders only, never real values)

# Server-side read-only Avalanche C-Chain RPC endpoint (HTTPS). Never expose via VITE_*.
AVALANCHE_RPC_URL=https://your-avalanche-mainnet-rpc-endpoint/ext/bc/C/rpc/

# Session signing secret for the SIWE wallet session (any long random string).
SESSION_SECRET=replace-with-a-long-random-string

# Optional: enable the /api/auth SIWE routes in production (default: dark).
# SYNDICATE_AUTH_ENABLED=true
