{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "artifacts/studio"],
      "port": 5173,
      "env": {
        "PORT": "5173",
        "BASE_PATH": "/"
      }
    },
    {
      "name": "api-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:rig", "--prefix", "artifacts/api-server"],
      "port": 5000,
      "env": {
        "PORT": "5000",
        "NODE_ENV": "development"
      }
    },
    {
      "name": "mockup-sandbox",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "artifacts/mockup-sandbox"],
      "port": 5174,
      "env": {
        "PORT": "5174",
        "BASE_PATH": "/"
      }
    }
  ]
}
