{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "studio",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/studio", "run", "dev"],
      "port": 5173,
      "env": {
        "PORT": "5173",
        "BASE_PATH": "/"
      }
    },
    {
      "name": "api-server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/api-server", "run", "dev"],
      "port": 5000,
      "env": {
        "PORT": "5000",
        "NODE_ENV": "development"
      }
    },
    {
      "name": "mockup-sandbox",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@workspace/mockup-sandbox", "run", "dev"],
      "port": 5174,
      "env": {
        "PORT": "5174",
        "BASE_PATH": "/"
      }
    }
  ]
}
