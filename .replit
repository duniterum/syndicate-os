modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.development]
VITE_WALLETCONNECT_PROJECT_ID = "227f2e3b4e4c1880a5385c9bc007b796"

[userenv.production]
VITE_WALLETCONNECT_PROJECT_ID = "227f2e3b4e4c1880a5385c9bc007b796"

[nix]
channel = "stable-25_05"
