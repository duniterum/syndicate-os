    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "qrcode": "^1.5.4",
    "satori": "^0.28.0",
    "viem": "^2.54.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@noble/hashes": "^1.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@workspace/os-contracts": "workspace:*",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
